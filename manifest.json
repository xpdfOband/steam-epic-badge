{
  "manifest_version": 3,
  "name": "Steam Epic Badge",
  "version": "1.0.0",
  "description": "在 Steam 商店页面标记曾在 Epic 平台赠送过的游戏",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://store-content.akamaized.net/*",
    "https://store-content.steamstatic.com/*",
    "https://store-site-backend-static-ipv4.ak.epicgames.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/epic-games.jpg"],
      "matches": ["https://store.steampowered.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "type": "module"
    }
  ]
}
